{
  "name": "jumpapp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:setup": "npm run db:reset && npm run db:configure",
    "db:reset": "npx prisma migrate reset --force",
    "db:configure": "psql $DATABASE_URL -c \"CREATE EXTENSION IF NOT EXISTS vector;\" && npx prisma db push && npm run db:fix-embeddings",
    "db:fix-embeddings": "echo \"DO \\$\\$ BEGIN IF EXISTS (SELECT FROM information_schema.tables WHERE table_name = 'Document') THEN ALTER TABLE \\\"Document\\\" DROP COLUMN IF EXISTS embedding; ALTER TABLE \\\"Document\\\" ADD COLUMN embedding vector(768); END IF; END \\$\\$;\" | psql $DATABASE_URL"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.0",
    "@google/generative-ai": "^0.24.1",
    "@heroui/react": "^2.8.5",
    "@hubspot/api-client": "^13.4.0",
    "@prisma/client": "^6.17.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@types/node-cron": "^3.0.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.24",
    "googleapis": "^162.0.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.545.0",
    "next": "13.5.11",
    "next-auth": "^4.24.11",
    "node-cron": "^4.2.1",
    "pgvector": "^0.2.1",
    "prisma": "^6.17.1",
    "react": "^18",
    "react-dom": "^18",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10",
    "postcss": "^8",
    "tailwindcss": "^3",
    "typescript": "^5"
  }
}
