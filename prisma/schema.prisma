
generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String? @db.Text
  access_token             String? @db.Text
  expires_at               Int?
  refresh_token_expires_in Int?
  token_type               String?
  scope                    String?
  id_token                 String? @db.Text
  session_state            String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  hubspotConnected      Boolean   @default(false)
  hubspotRefreshToken   String?   @db.Text
  hubspotPortalId       String?
  hubspotConnectedAt    DateTime?
  
  googleConnected       Boolean   @default(false)
  googleRefreshToken    String?   @db.Text
  googleConnectedAt     DateTime?

  accounts Account[]
  sessions Session[]
  emails   Email[]
  hubspotContacts HubSpotContact[]
  hubspotNotes    HubSpotNote[]
  calendarEvents  CalendarEvent[]
  documents       Document[]
  chats           Chat[]
  agentTasks      AgentTask[]
  agentMemory     AgentMemory[]
  agentWorkflows  AgentWorkflow[]
  tasks           Task[]
  ongoingInstructions OngoingInstruction[]
  integrations    Integration[]
  webhookSubscriptions WebhookSubscription[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Email {
  id            String   @id @default(cuid())
  userId        String
  gmailId       String   @unique
  threadId      String
  labelIds      String[]
  snippet       String   @db.Text
  from          String
  to            String[]
  cc            String[]
  bcc           String[]
  subject       String?
  body          String?  @db.Text
  bodyHtml      String?  @db.Text
  attachments   Json[]
  internalDate  DateTime
  isRead        Boolean  @default(false)
  isStarred     Boolean  @default(false)
  isImportant   Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, internalDate])
  @@index([gmailId])
}

model HubSpotContact {
  id                String   @id @default(cuid())
  userId            String
  hubspotId         String   @unique
  email             String?
  firstname         String?
  lastname          String?
  phone             String?
  company           String?
  jobtitle          String?
  lifecyclestage    String?
  properties        Json
  associations      Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  hubspotCreatedAt  DateTime
  hubspotUpdatedAt  DateTime
  
  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  notes HubSpotNote[]
  
  @@index([userId])
  @@index([hubspotId])
}

model HubSpotNote {
  id               String   @id @default(cuid())
  userId           String
  hubspotId        String   @unique
  contactId        String?
  noteBody         String   @db.Text
  properties       Json
  associations     Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  hubspotCreatedAt DateTime
  hubspotUpdatedAt DateTime
  
  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact HubSpotContact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  
  @@index([userId])
  @@index([hubspotId])
}

model CalendarEvent {
  id              String    @id @default(cuid())
  userId          String
  googleEventId   String    @unique
  calendarId      String
  summary         String?
  description     String?   @db.Text
  location        String?
  startDateTime   DateTime
  startTimeZone   String?
  endDateTime     DateTime
  endTimeZone     String?
  isAllDay        Boolean   @default(false)
  status          String?
  organizer       Json?
  attendees       Json[]
  recurrence      String[]
  reminders       Json?
  attachments     Json[]
  conferenceData  Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  googleCreatedAt DateTime
  googleUpdatedAt DateTime
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, startDateTime])
  @@index([googleEventId])
}

model Document {
  id            String                  @id @default(cuid())
  userId        String
  sourceType    String
  sourceId      String
  title         String?
  content       String                  @db.Text
  metadata      Json?
  embedding     Unsupported("vector")?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, sourceId])
  @@index([userId])
  @@index([sourceType, sourceId])
}

model Chat {
  id        String    @id @default(cuid())
  userId    String
  title     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]
  
  @@index([userId, updatedAt])
}

model Message {
  id        String   @id @default(cuid())
  chatId    String
  role      String
  content   String   @db.Text
  metadata  Json?    // Store sources, email cards, tools used, etc.
  createdAt DateTime @default(now())
  
  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  
  @@index([chatId, createdAt])
}

model AgentTask {
  id            String    @id @default(cuid())
  userId        String
  type          String
  status        String    @default("pending")
  priority      Int       @default(0)
  data          Json
  context       Json?
  result        Json?
  error         String?
  parentTaskId  String?
  retryCount    Int       @default(0)
  maxRetries    Int       @default(3)
  scheduledFor  DateTime?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentTask   AgentTask?        @relation("TaskHierarchy", fields: [parentTaskId], references: [id])
  subtasks     AgentTask[]       @relation("TaskHierarchy")
  memory       AgentMemory[]
  toolCalls    AgentToolCall[]
  
  @@index([userId, status])
  @@index([scheduledFor])
  @@index([parentTaskId])
}

model AgentMemory {
  id        String    @id @default(cuid())
  userId    String
  taskId    String?
  type      String    
  key       String 
  value     Json     
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  
  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  task AgentTask? @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  @@unique([userId, key])
  @@index([taskId])
  @@index([expiresAt])
}

model AgentToolCall {
  id          String    @id @default(cuid())
  taskId      String
  tool        String    
  input       Json      
  output      Json?     
  status      String    @default("pending") 
  error       String?   
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  
  task AgentTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  @@index([taskId])
  @@index([status])
}

model AgentWorkflow {
  id          String   @id @default(cuid())
  userId      String
  name        String   
  description String?
  steps       Json     
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, isActive])
}

model Task {
  id          String    @id @default(cuid())
  userId      String
  title       String
  description String    @db.Text
  status      String    @default("PENDING")
  priority    String    @default("medium")
  dueDate     DateTime?
  assignedTo  String?
  relatedTo   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, status])
  @@index([dueDate])
}

model OngoingInstruction {
  id            String   @id @default(cuid())
  userId        String
  instruction   String   @db.Text
  triggerEvents String[]
  priority      Int      @default(5)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, active])
}

model Integration {
  id           String    @id @default(cuid())
  userId       String
  type         String
  accessToken  String?   @db.Text
  refreshToken String?   @db.Text
  portalId     String?
  isActive     Boolean   @default(true)
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, type])
  @@index([userId, isActive])
}

model WebhookSubscription {
  id               String    @id @default(cuid())
  userId           String
  channelId        String    @unique
  resourceId       String?
  resourceType     String    // 'gmail' or 'calendar'
  resourceUri      String?
  token            String?
  expiresAt        DateTime?
  metadata         Json?     // Additional data like calendarId for calendar subscriptions
  isActive         Boolean   @default(true)
  lastProcessedAt  DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, resourceType])
  @@index([expiresAt])
}